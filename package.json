{
  "name": "version-bump-action",
  "version": "0.2.0",
  "private": true,
  "description": "GitHub Action that bumps SemVer project versions and opens a pull request.",
  "license": "MIT",
  "author": {
    "name": "Jose F. Ruiz",
    "url": "https://github.com/jfrz38"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jfrz38/version-bump-action.git"
  },
  "bugs": {
    "url": "https://github.com/jfrz38/version-bump-action/issues"
  },
  "homepage": "https://github.com/jfrz38/version-bump-action#readme",
  "keywords": [
    "github-action",
    "github-actions",
    "version-bump",
    "semver",
    "pull-request",
    "gradle",
    "npm"
  ],
  "main": "dist/index.js",
  "type": "commonjs",
  "packageManager": "pnpm@10.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild ./src/main.ts --bundle --platform=node --target=node20 --format=cjs --minify --outfile=dist/index.js",
    "lint": "eslint .",
    "package": "pnpm run build",
    "test": "vitest run tests/unit tests/integration",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm run typecheck && pnpm test && pnpm run build"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vitest": "4.1.5"
  }
}
